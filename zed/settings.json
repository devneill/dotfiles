{
  // ---- Functional ----
  "vim_mode": true,
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "ensure_final_newline_on_save": true,
  "tab_size": 2,
  "relative_line_numbers": true,
  "diff_view_style": "unified",
  "pane_split_direction_vertical": "right",
  "buffer_line_height": "comfortable",
  "buffer_font_weight": 400.0,
  "indent_guides": {
    "enabled": true
  },
  "inlay_hints": {
    "enabled": true
  },
  "git": {
    "inline_blame": { "enabled": true }
  },
  "prettier": {
    "allowed": false
  },
  "session": {
    "trust_all_worktrees": true
  },
  "shell": {
    "program": "/opt/homebrew/bin/fish"
  },

  // ---- AI / Agent ----
  "edit_predictions": {
    "provider": "zed"
  },
  "agent_buffer_font_size": 13.0,
  "agent_ui_font_size": 15.0,
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
      "default_mode": "bypassPermissions"
    }
  },
  "agent": {
    "tool_permissions": {
      "default": "allow"
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-3.5-sonnet"
    },
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini"
    },
    "dock": "left"
  },

  // ---- Theme ----
  "theme": {
    "light": "One Light",
    "dark": "One Dark - Darkened"
  },
  "icon_theme": "Zed (Default)",

  // ---- Fonts ----
  "cursor_blink": false,
  "ui_font_size": 15.0,
  "ui_font_family": "Geist",
  "buffer_font_size": 13.0,
  "buffer_font_family": "Geist Mono",

  // ---- Terminal ----
  "terminal": {
    "shell": {
      "program": "/opt/homebrew/bin/fish"
    },
    "font_family": "GeistMono Nerd Font",
    "font_size": 14,
    "button": false
  },

  // ---- Panels ----
  "tab_bar": {
    "show": true
  },
  "scrollbar": {
    "show": "auto"
  },
  "project_panel": {
    "button": false,
    "indent_size": 12,
    "default_width": 300,
    "dock": "right"
  },
  "outline_panel": {
    "button": false,
    "dock": "right"
  },
  "collaboration_panel": {
    "button": false,
    "dock": "right"
  },
  "notification_panel": {
    "button": false
  }
}
