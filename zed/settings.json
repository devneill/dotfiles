{
  "vim_mode": true,
  "ui_font_family": "Geist",
  "ui_font_size": 16,
  "buffer_font_family": "Geist Mono",
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Ayu Dark",
  },
  "terminal": {
    "shell": {
      "program": "/opt/homebrew/bin/fish",
    },
    "font_family": "GeistMono Nerd Font",
    "font_size": 14,
  },
  "format_on_save": "on",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "git": {
    "inline_blame": {
      "enabled": true,
    },
  },
  "inlay_hints": {
    "enabled": true,
  },
  "relative_line_numbers": "enabled",
  "scrollbar": {
    "show": "auto",
  },
  "indent_guides": {
    "enabled": true,
  },
  "tab_size": 2,
}
